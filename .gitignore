# CharaPicker/.gitignore

# Local editor and agent state
.vscode/
.VSCodeCounter/
.codex/

# Generated/runtime assets
config.yaml
build/
dist/
release/
bin/*
!bin/ARCHITECTURE.md
models/*
!models/ARCHITECTURE.md
projects/*
!projects/ARCHITECTURE.md
.ruff_cache/
.pytest_cache/
.tmp_*/

# Local notes and logs
*.txt
!requirements.txt
*.log
log/*

# Python generated files
__pycache__/
*.py[cod]
